, "date_joined": "2026-04-20T20:53:56.950Z", "groups": [], "user_permissions": []}}, {"model": "auth.user", "fields": {"password": "pbkdf2_sha256$600000$uRWMfH3ni7DHKY2DdPCbzH$/eAvhEttCQ/jeE/r3DfrniGSqf8yoo5vDsE9ydbHwOM=", "last_login": null, "is_superuser": false, "username": "piotr", "first_name": "Piotr", "last_name": "Zielinski", "email": "piotr@example.com", "is_staff": false, "is_active": true, "date_joined": "2026-04-20T20:53:57.103Z", "groups": [], "user_permissions": []}}, {"model": "cars.brand", "pk": 1, "fields": {"name": "BYD", "slug": "byd", "description": "BYD Auto (chiń. upr.: 比亚迪汽车) – chiński koncern motoryzacyjny zajmujący się produkcją samochodów osobowych, ciężarowych i użytkowych oraz autobusów, z siedzibą w Shenzhen, działający od 2003 roku. Należy do chińskiego holdingu BYD.", "description_en": "", "description_pl": "", "logo": "brands/BYD.png", "founded_year": 1995, "country": "China", "website": "https://www.byd.com", "created_at": "2026-04-20T20:53:56.589Z", "updated_at": "2026-04-21T06:03:25.022Z", "is_active": true}}, {"model": "cars.brand", "pk": 2, "fields": {"name": "Geely", "slug": "geely", "description": "Geely Automobile (chiń. upr. 吉利汽车; chiń. trad. 吉利汽車; pinyin Jílì Qìchē) – chiński producent samochodów osobowych z siedzibą w Hangzhou, w prowincji Zhejiang. Jest głównym oddziałem samochodowym koncernu Zhejiang Geely Holding Group.\r\n\r\nPrzedsiębiorstwo rozpoczęło działalność w 1986 od produkcji chłodziarek. Od 1992 wytwarzało części do motocykli, od 1994 kompletne motocykle, zaś od 1998 samochody osobowe.\r\n\r\nOd połowy 2008 pojawiały się informacje, że koncern Geely prowadzi rozmowy z koncernem Ford Motor Company na temat możliwości odkupienia firmy Volvo, która ostatecznie została nabyta 29 marca 2010 za cenę 1,8 miliarda dolarów. W lutym 2013 koncern stał się właścicielem spółki The London Taxi Company.\r\n\r\nW 2013 Geely poprzez spółkę BelGee rozpoczęło montaż pojazdów w Borysowskich Zakładach Samochodowych i Traktorowych Urządzeń Elektrycznych na Białorusi. Koncern planuje budowę nowych zakładów w okolicach Borysowa, których produkcja wyniesie docelowo 120 tys. aut rocznie", "description_en": "", "description_pl": "", "logo": "brands/GEELY.png", "founded_year": 1986, "country": "China", "website": "https://global.geely.com", "created_at": "2026-04-20T20:53:56.593Z", "updated_at": "2026-04-21T06:05:38.347Z", "is_active": true}}, {"model": "cars.brand", "pk": 3, "fields": {"name": "NIO", "slug": "nio", "description": "Nio (chiń. upr. 蔚来) – chiński koncern samochodowy zajmujący się produkcją elektrycznych samochodów, akumulatorów i stacji wymiany baterii, a także odzieży i elektroniki użytkowej, z siedzibą w Szanghaju, działający od 2014 roku.", "description_en": "", "description_pl": "", "logo": "brands/NIO.png", "founded_year": 2014, "country": "China", "website": "https://www.nio.com", "created_at": "2026-04-20T20:53:56.597Z", "updated_at": "2026-04-21T06:08:23.807Z", "is_active": true}}, {"model": "cars.brand", "pk": 4, "fields": {"name": "Chery", "slug": "chery", "description": "Chery demo brand profile.", "description_en": "", "description_pl": "", "logo": "", "founded_year": 1997, "country": "China", "website": "https://www.cheryinternational.com", "created_at": "2026-04-20T20:53:56.601Z", "updated_at": "2026-04-20T20:53:56.601Z", "is_active": true}}, {"model": "cars.brand", "pk": 5, "fields": {"name": "Xpeng", "slug": "xpeng", "description": "Xpeng (also written as XPENG or 小鹏汽车) is a Chinese smart EV manufacturer founded in 2014 and listed on the NYSE. The company is known for its in-house developed XNGP autonomous driving system and strong software integration, targeting tech-savvy EV buyers.", "description_en": "", "description_pl": "", "logo": "brands/xpeng_placeholder.png", "founded_year": 2014, "country": "China", "website": "https://www.xpeng.com", "created_at": "2026-04-20T22:29:28.258Z", "updated_at": "2026-04-20T22:29:28.341Z", "is_active": true}}, {"model": "cars.brand", "pk": 6, "fields": {"name": "Li Auto", "slug": "li-auto", "description": "Li Auto (理想汽车) is a Chinese EV company founded in 2015 specialising in extended-range electric vehicles (EREV). Its range-extender approach eliminates range anxiety while charging infrastructure grows. Li Auto became one of the fastest-growing EV startups in China and listed on Nasdaq in 2020.", "description_en": "", "description_pl": "", "logo": "brands/li-auto_placeholder.png", "founded_year": 2015, "country": "China", "website": "https://www.lixiang.com", "created_at": "2026-04-20T22:29:28.354Z", "updated_at": "2026-04-20T22:29:28.421Z", "is_active": true}}, {"model": "cars.brand", "pk": 7, "fields": {"name": "Haval", "slug": "haval", "description": "Haval is Great Wall Motor's dedicated SUV brand and one of the best-selling SUV marques in China. Established as a standalone brand in 2013, Haval now exports to over 60 countries. Its H-series and Jolion models dominate the affordable SUV segment across Eastern Europe and the Middle East.", "description_en": "", "description_pl": "", "logo": "brands/haval_placeholder.png", "founded_year": 2013, "country": "China", "website": "https://www.haval.com", "created_at": "2026-04-20T22:29:28.435Z", "updated_at": "2026-04-20T22:29:28.499Z", "is_active": true}}, {"model": "cars.brand", "pk": 8, "fields": {"name": "MG", "slug": "mg", "description": "MG (Morris Garages) was a beloved British sports car brand, now owned by SAIC Motor since 2007. Under Chinese ownership MG reinvented itself as a modern EV and affordable car brand with strong sales in Europe, Australia, and Southeast Asia. The MG4 Electric was Europe's best-selling Chinese EV in 2023.", "description_en": "MG (Morris Garages) was a beloved British sports car brand, now owned by SAIC Motor since 2007. Under Chinese ownership MG reinvented itself as a modern EV and affordable car brand with strong sales in Europe, Australia, and Southeast Asia. The MG4 Electric was Europe's best-selling Chinese EV in 2023.", "description_pl": "", "logo": "brands/mg.png", "founded_year": 1924, "country": "China", "website": "https://www.mgmotor.eu", "created_at": "2026-04-20T22:29:28.512Z", "updated_at": "2026-04-21T07:08:26.941Z", "is_active": true}}, {"model": "cars.brand", "pk": 9, "fields": {"name": "GAC Aion", "slug": "gac-aion", "description": "GAC Aion is the electric vehicle sub-brand of GAC Group (Guangzhou Automobile Corporation), one of China's largest state-owned automakers. Launched in 2017, Aion focuses exclusively on battery-electric vehicles and is China's third-largest EV brand by sales volume.", "description_en": "GAC Aion is the electric vehicle sub-brand of GAC Group (Guangzhou Automobile Corporation), one of China's largest state-owned automakers. Launched in 2017, Aion focuses exclusively on battery-electric vehicles and is China's third-largest EV brand by sales volume.", "description_pl": "", "logo": "brands/gac.png", "founded_year": 2017, "country": "China", "website": "https://www.aion.gac.com.cn", "created_at": "2026-04-20T22:29:28.614Z", "updated_at": "2026-04-21T07:07:07.827Z", "is_active": true}}, {"model": "cars.brand", "pk": 10, "fields": {"name": "Changan", "slug": "changan", "description": "Changan Automobile (长安汽车) is one of China's four largest state-owned car groups, tracing its roots to an arsenal founded in 1862. Today Changan is a leading producer of passenger cars and commercial vehicles, and the parent of the premium Deepal and Avatr EV brands (developed with CATL and Huawei).", "description_en": "Changan Automobile (长安汽车) is one of China's four largest state-owned car groups, tracing its roots to an arsenal founded in 1862. Today Changan is a leading producer of passenger cars and commercial vehicles, and the parent of the premium Deepal and Avatr EV brands (developed with CATL and Huawei).", "description_pl": "", "logo": "brands/changan.png", "founded_year": 1862, "country": "China", "website": "https://www.changan.com.cn", "created_at": "2026-04-20T22:29:28.694Z", "updated_at": "2026-04-21T07:05:30.532Z", "is_active": true}}, {"model": "cars.carmodel", "pk": 1, "fields": {"brand": 1, "name": "Seal", "slug": "byd-seal-2022", "vehicle_type": "sedan", "year_introduced": 2022, "description": "Electric sport sedan", "image": "", "engine_type": "BEV", "horsepower": 530, "acceleration": "3.8", "top_speed": 180, "fuel_consumption": "15.0 kWh/100km", "price_range": "$40k-$55k", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T20:53:56.612Z", "updated_at": "2026-04-20T20:53:56.612Z"}}, {"model": "cars.carmodel", "pk": 2, "fields": {"brand": 1, "name": "Atto 3", "slug": "byd-atto-3-2022", "vehicle_type": "crossover", "year_introduced": 2022, "description": "Compact electric crossover", "image": "", "engine_type": "BEV", "horsepower": 201, "acceleration": "7.3", "top_speed": 160, "fuel_consumption": "16.0 kWh/100km", "price_range": "$30k-$40k", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T20:53:56.617Z", "updated_at": "2026-04-20T21:38:11.833Z"}}, {"model": "cars.carmodel", "pk": 3, "fields": {"brand": 2, "name": "Coolray", "slug": "geely-coolray-2018", "vehicle_type": "suv", "year_introduced": 2018, "description": "Subcompact SUV", "image": "", "engine_type": "1.5T", "horsepower": 177, "acceleration": "7.9", "top_speed": 195, "fuel_consumption": "6.4 L/100km", "price_range": "$15k-$22k", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T20:53:56.624Z", "updated_at": "2026-04-20T20:53:56.624Z"}}, {"model": "cars.carmodel", "pk": 4, "fields": {"brand": 2, "name": "Emgrand", "slug": "geely-emgrand-2009", "vehicle_type": "sedan", "year_introduced": 2009, "description": "Affordable family sedan", "image": "", "engine_type": "1.5L", "horsepower": 126, "acceleration": "11.5", "top_speed": 180, "fuel_consumption": "6.0 L/100km", "price_range": "$10k-$16k", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T20:53:56.629Z", "updated_at": "2026-04-20T20:53:56.629Z"}}, {"model": "cars.carmodel", "pk": 5, "fields": {"brand": 3, "name": "ET5", "slug": "nio-et5-2021", "vehicle_type": "sedan", "year_introduced": 2021, "description": "Premium electric sedan", "image": "", "engine_type": "BEV", "horsepower": 483, "acceleration": "4.0", "top_speed": 200, "fuel_consumption": "14.8 kWh/100km", "price_range": "$45k-$60k", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T20:53:56.634Z", "updated_at": "2026-04-20T20:53:56.634Z"}}, {"model": "cars.carmodel", "pk": 6, "fields": {"brand": 4, "name": "Tiggo 8", "slug": "chery-tiggo-8-2018", "vehicle_type": "suv", "year_introduced": 2018, "description": "Mid-size 7-seat SUV", "image": "", "engine_type": "1.6T", "horsepower": 197, "acceleration": "8.9", "top_speed": 200, "fuel_consumption": "7.8 L/100km", "price_range": "$18k-$28k", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T20:53:56.638Z", "updated_at": "2026-04-20T20:53:56.638Z"}}, {"model": "cars.carmodel", "pk": 7, "fields": {"brand": 1, "name": "Atto 3", "slug": "atto-3", "vehicle_type": "suv", "year_introduced": 2021, "description": "The BYD Atto 3 (also known as Yuan Plus) is a compact electric SUV powered by BYD's Blade Battery technology. It offers up to 420 km of range and a 150 kW electric motor, making it one of BYD's most popular international models.", "image": "", "engine_type": "BEV – 150 kW electric motor", "horsepower": 204, "acceleration": "7.3", "top_speed": 160, "fuel_consumption": "", "price_range": "130 000 – 175 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.234Z", "updated_at": "2026-04-20T22:29:28.234Z"}}, {"model": "cars.carmodel", "pk": 8, "fields": {"brand": 1, "name": "Tang", "slug": "tang", "vehicle_type": "suv", "year_introduced": 2018, "description": "The BYD Tang is a full-size electric and plug-in hybrid SUV offering seating for up to 7 passengers. The fully electric version delivers up to 505 km of range with dual-motor AWD and 380 kW combined output.", "image": "", "engine_type": "BEV / PHEV – dual-motor AWD", "horsepower": 517, "acceleration": "4.6", "top_speed": 180, "fuel_consumption": "", "price_range": "240 000 – 290 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.241Z", "updated_at": "2026-04-20T22:29:28.241Z"}}, {"model": "cars.carmodel", "pk": 9, "fields": {"brand": 3, "name": "ET5", "slug": "et5", "vehicle_type": "sedan", "year_introduced": 2022, "description": "The Nio ET5 is a mid-size electric sedan packed with LIDAR-based autonomous driving hardware. Available with 75 kWh and 100 kWh battery packs (or via battery-swap), it offers up to 590 km WLTP range.", "image": "", "engine_type": "BEV – 360 kW dual-motor AWD", "horsepower": 489, "acceleration": "4.3", "top_speed": 200, "fuel_consumption": "", "price_range": "230 000 – 280 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.248Z", "updated_at": "2026-04-20T22:29:28.248Z"}}, {"model": "cars.carmodel", "pk": 10, "fields": {"brand": 3, "name": "EL6", "slug": "el6", "vehicle_type": "suv", "year_introduced": 2022, "description": "The Nio EL6 (ES6 in some markets) is a 5-seat electric SUV with sleek fastback styling. It supports Nio's battery-swap network and comes with full ADAS capability including highway pilot.", "image": "", "engine_type": "BEV – 340 kW dual-motor AWD", "horsepower": 462, "acceleration": "4.5", "top_speed": 200, "fuel_consumption": "", "price_range": "250 000 – 295 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.253Z", "updated_at": "2026-04-20T22:29:28.253Z"}}, {"model": "cars.carmodel", "pk": 11, "fields": {"brand": 5, "name": "P7", "slug": "p7", "vehicle_type": "sedan", "year_introduced": 2020, "description": "The Xpeng P7 is a sleek all-electric sports sedan featuring a drag coefficient of only 0.236 Cd. It delivers over 480 km of range and supports Xpeng's XPILOT highway and city autonomous driving.", "image": "", "engine_type": "BEV – rear or all-wheel drive", "horsepower": 316, "acceleration": "4.3", "top_speed": 170, "fuel_consumption": "", "price_range": "170 000 – 220 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.346Z", "updated_at": "2026-04-20T22:29:28.346Z"}}, {"model": "cars.carmodel", "pk": 12, "fields": {"brand": 5, "name": "G9", "slug": "g9", "vehicle_type": "suv", "year_introduced": 2022, "description": "The Xpeng G9 is a large electric SUV with 800V ultra-fast charging (up to 300 kW), enabling a 200 km top-up in just 5 minutes. It seats five and supports full XNGP autonomous driving on compatible roads.", "image": "", "engine_type": "BEV – 405 kW dual-motor AWD", "horsepower": 551, "acceleration": "3.9", "top_speed": 200, "fuel_consumption": "", "price_range": "240 000 – 300 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.350Z", "updated_at": "2026-04-20T22:29:28.350Z"}}, {"model": "cars.carmodel", "pk": 13, "fields": {"brand": 6, "name": "L9", "slug": "l9", "vehicle_type": "suv", "year_introduced": 2022, "description": "The Li Auto L9 is a flagship 6-seat large SUV with an extended-range electric drivetrain. The 1.5T range extender tops up a 44.5 kWh battery, giving a combined range of over 1 000 km and all-terrain AWD capability.", "image": "", "engine_type": "EREV – 330 kW dual-motor + 1.5T range extender", "horsepower": 449, "acceleration": "5.3", "top_speed": 180, "fuel_consumption": "", "price_range": "270 000 – 310 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.425Z", "updated_at": "2026-04-20T22:29:28.425Z"}}, {"model": "cars.carmodel", "pk": 14, "fields": {"brand": 6, "name": "L7", "slug": "l7", "vehicle_type": "suv", "year_introduced": 2023, "description": "The Li Auto L7 is a 5-seat mid-size SUV sharing the EREV architecture with its larger siblings. It targets family buyers seeking long-range capability without compromising on interior space or advanced technology.", "image": "", "engine_type": "EREV – 260 kW + 1.5T range extender", "horsepower": 354, "acceleration": "5.3", "top_speed": 180, "fuel_consumption": "", "price_range": "240 000 – 275 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.430Z", "updated_at": "2026-04-20T22:29:28.430Z"}}, {"model": "cars.carmodel", "pk": 15, "fields": {"brand": 7, "name": "H6", "slug": "h6", "vehicle_type": "suv", "year_introduced": 2011, "description": "The Haval H6 is China's best-selling SUV for over a decade. The current generation uses a 1.5T or 2.0T turbo engine paired with a 7-speed DCT. A hybrid version achieves fuel consumption of just 5.5 L/100 km.", "image": "", "engine_type": "ICE – 2.0T / HEV", "horsepower": 197, "acceleration": "8.5", "top_speed": 185, "fuel_consumption": "5.5", "price_range": "110 000 – 145 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.504Z", "updated_at": "2026-04-20T22:29:28.504Z"}}, {"model": "cars.carmodel", "pk": 16, "fields": {"brand": 7, "name": "Jolion", "slug": "jolion", "vehicle_type": "crossover", "year_introduced": 2021, "description": "The Haval Jolion is a compact crossover built on GWM's Lemon platform. It is offered in standard, hybrid, and plug-in hybrid versions. The PHEV variant claims a combined range of over 1 100 km.", "image": "", "engine_type": "ICE / PHEV – 1.5T", "horsepower": 150, "acceleration": "9.5", "top_speed": 180, "fuel_consumption": "6.2", "price_range": "95 000 – 130 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.508Z", "updated_at": "2026-04-20T22:29:28.508Z"}}, {"model": "cars.carmodel", "pk": 17, "fields": {"brand": 8, "name": "MG4 Electric", "slug": "mg4-electric", "vehicle_type": "hatchback", "year_introduced": 2022, "description": "The MG4 Electric is a compact 5-door hatchback EV built on MG's new MSP (Modular Scalable Platform). Rear-wheel drive variants offer up to 435 km WLTP range. The XPOWER dual-motor version hits 100 km/h in 3.8 s.", "image": "", "engine_type": "BEV – 150 kW / 320 kW XPOWER", "horsepower": 204, "acceleration": "7.9", "top_speed": 160, "fuel_consumption": "", "price_range": "115 000 – 165 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.587Z", "updated_at": "2026-04-20T22:29:28.587Z"}}, {"model": "cars.carmodel", "pk": 18, "fields": {"brand": 8, "name": "ZS EV", "slug": "zs-ev", "vehicle_type": "suv", "year_introduced": 2019, "description": "The MG ZS EV is a compact electric SUV and one of the most affordable EVs on the European market. The refreshed long-range model provides up to 440 km WLTP range and 115 kW of power.", "image": "", "engine_type": "BEV – 115 kW", "horsepower": 156, "acceleration": "8.6", "top_speed": 175, "fuel_consumption": "", "price_range": "110 000 – 135 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.592Z", "updated_at": "2026-04-20T22:29:28.592Z"}}, {"model": "cars.carmodel", "pk": 19, "fields": {"brand": 2, "name": "Galaxy L7", "slug": "galaxy-l7", "vehicle_type": "suv", "year_introduced": 2023, "description": "The Geely Galaxy L7 is a mid-size PHEV SUV under Geely's premium Galaxy sub-brand. It uses the Thor Hi-X hybrid system with a 1.5T engine and large 19.1 kWh battery for over 120 km of pure electric range.", "image": "", "engine_type": "PHEV – Thor Hi-X 1.5T + 135 kW motor", "horsepower": 340, "acceleration": "6.9", "top_speed": 190, "fuel_consumption": "1.3", "price_range": "140 000 – 185 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.598Z", "updated_at": "2026-04-20T22:29:28.598Z"}}, {"model": "cars.carmodel", "pk": 20, "fields": {"brand": 4, "name": "Tiggo 8 Pro", "slug": "tiggo-8-pro", "vehicle_type": "suv", "year_introduced": 2020, "description": "The Chery Tiggo 8 Pro is a 7-seat SUV available with 1.6T and 2.0T turbocharged engines, as well as a PHEV variant. It features a large panoramic sunroof, three-row seating, and a 25.6-inch dual-screen dashboard.", "image": "", "engine_type": "ICE / PHEV – 1.6T / 2.0T", "horsepower": 254, "acceleration": "7.5", "top_speed": 185, "fuel_consumption": "7.8", "price_range": "120 000 – 165 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.603Z", "updated_at": "2026-04-20T22:29:28.603Z"}}, {"model": "cars.carmodel", "pk": 21, "fields": {"brand": 4, "name": "Omoda 5", "slug": "omoda-5", "vehicle_type": "crossover", "year_introduced": 2022, "description": "The Chery Omoda 5 is a sporty compact crossover from Chery's international sub-brand. Available in ICE (1.6T) and full-electric versions, it targets young urban buyers with expressive styling and connected tech.", "image": "", "engine_type": "ICE / BEV – 1.6T / 150 kW", "horsepower": 204, "acceleration": "7.6", "top_speed": 185, "fuel_consumption": "7.2", "price_range": "105 000 – 145 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.609Z", "updated_at": "2026-04-20T22:29:28.609Z"}}, {"model": "cars.carmodel", "pk": 22, "fields": {"brand": 9, "name": "Aion S", "slug": "aion-s", "vehicle_type": "sedan", "year_introduced": 2019, "description": "The GAC Aion S is a compact electric sedan and one of China's best-selling EVs. The 2023 model offers up to 603 km CLTC range, fast DC charging, and a connected cockpit powered by Qualcomm 8155.", "image": "", "engine_type": "BEV – 130 kW", "horsepower": 177, "acceleration": "7.9", "top_speed": 150, "fuel_consumption": "", "price_range": "90 000 – 125 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.687Z", "updated_at": "2026-04-20T22:29:28.687Z"}}, {"model": "cars.carmodel", "pk": 23, "fields": {"brand": 9, "name": "Aion V", "slug": "aion-v", "vehicle_type": "suv", "year_introduced": 2020, "description": "The GAC Aion V is a mid-size electric SUV with LiDAR-based ADiGO PILOT autonomous driving system. It supports 80 kW DC fast charging and is available in long-range (up to 600 km CLTC) and performance variants.", "image": "", "engine_type": "BEV – 150 kW", "horsepower": 204, "acceleration": "8.0", "top_speed": 185, "fuel_consumption": "", "price_range": "115 000 – 155 000 PLN", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.691Z", "updated_at": "2026-04-20T22:29:28.691Z"}}, {"model": "cars.carmodel", "pk": 24, "fields": {"brand": 10, "name": "CS75 Plus", "slug": "cs75-plus", "vehicle_type": "suv", "year_introduced": 2019, "description": "The Changan CS75 Plus is a 5-seat compact SUV and one of China's top-selling domestic models. The Blue Whale 2.0T engine produces 233 hp, paired with an 8-speed automatic for smooth highway cruising.", "image": "", "engine_type": "ICE – Blue Whale 2.0T", "horsepower": 233, "acceleration": "7.9", "top_speed": 195, "fuel_consumption": "7.5", "price_range": "105 000 – 140 000 PLN", "production_status": "active", "is_featured": false, "created_at": "2026-04-20T22:29:28.771Z", "updated_at": "2026-04-20T22:29:28.771Z"}}, {"model": "cars.carmodel", "pk": 25, "fields": {"brand": 10, "name": "Deepal S7", "slug": "deepal-s7", "vehicle_type": "suv", "year_introduced": 2023, "description": "The Deepal S7 is Changan's premium EV SUV under its Deepal sub-brand. Built on an 800V platform, it supports 4C ultra-fast charging, delivering 400 km of range in around 10 minutes at compatible stations.", "image": "cars/changandeepals7.png", "engine_type": "BEV – 160 kW / 250 kW AWD", "horsepower": 340, "acceleration": "4.9", "top_speed": 200, "fuel_consumption": "", "price_range": "USD $67k-89k", "production_status": "active", "is_featured": true, "created_at": "2026-04-20T22:29:28.775Z", "updated_at": "2026-04-21T07:03:26.972Z"}}, {"model": "opinions.opinion", "pk": 1, "fields": {"car_model": 1, "author": ["anna"], "title": "Great balance of comfort and range", "content": "Daily commuting is smooth and the cabin feels premium.", "rating": 5, "is_verified_owner": true, "helpful_count": 3, "unhelpful_count": 0, "is_approved": true, "created_at": "2026-04-20T20:53:57.256Z", "updated_at": "2026-04-20T20:53:57.401Z"}}, {"model": "opinions.opinion", "pk": 2, "fields": {"car_model": 1, "author": ["marek"], "title": "Solid EV sedan", "content": "Strong acceleration and stable handling on highways.", "rating": 4, "is_verified_owner": false, "helpful_count": 0, "unhelpful_count": 0, "is_approved": true, "created_at": "2026-04-20T20:53:57.263Z", "updated_at": "2026-04-20T20:53:57.397Z"}}, {"model": "opinions.opinion", "pk": 3, "fields": {"car_model": 2, "author": ["olga"], "title": "Practical city crossover", "content": "Easy to park and good infotainment, but trunk could be bigger.", "rating": 4, "is_verified_owner": true, "helpful_count": 0, "unhelpful_count": 0, "is_approved": true, "created_at": "2026-04-20T20:53:57.268Z", "updated_at": "2026-04-20T20:53:57.393Z"}}, {"model": "opinions.opinion", "pk": 4, "fields": {"car_model": 3, "author": ["piotr"], "title": "Fun and affordable", "content": "Turbo engine feels lively and suspension is decent.", "rating": 4, "is_verified_owner": false, "helpful_count": 1, "unhelpful_count": 1, "is_approved": true, "created_at": "2026-04-20T20:53:57.273Z", "updated_at": "2026-04-20T20:53:57.389Z"}}, {"model": "opinions.opinion", "pk": 5, "fields": {"car_model": 4, "author": ["anna"], "title": "Budget friendly choice", "content": "Simple interior but reliable for daily family use.", "rating": 3, "is_verified_owner": false, "helpful_count": 0, "unhelpful_count": 1, "is_approved": true, "created_at": "2026-04-20T20:53:57.278Z", "updated_at": "2026-04-20T20:53:57.385Z"}}, {"model": "opinions.opinion", "pk": 6, "fields": {"car_model": 5, "author": ["marek"], "title": "Premium EV experience", "content": "Excellent tech features and very quiet ride quality.", "rating": 5, "is_verified_owner": true, "helpful_count": 2, "unhelpful_count": 0, "is_approved": true, "created_at": "2026-04-20T20:53:57.283Z", "updated_at": "2026-04-20T20:53:57.382Z"}}, {"model": "opinions.opinion", "pk": 7, "fields": {"car_model": 6, "author": ["olga"], "title": "Good value 7-seater", "content": "Spacious second and third rows, acceptable fuel economy.", "rating": 4, "is_verified_owner": false, "helpful_count": 1, "unhelpful_count": 0, "is_approved": true, "created_at": "2026-04-20T20:53:57.288Z", "updated_at": "2026-04-20T20:53:57.378Z"}}, {"model": "opinions.opinion", "pk": 8, "fields": {"car_model": 5, "author": ["piotr"], "title": "Powerful but pricey", "content": "Performance is great, software still needs occasional fixes.", "rating": 4, "is_verified_owner": false, "helpful_count": 0, "unhelpful_count": 0, "is_approved": true, "created_at": "2026-04-20T20:53:57.293Z", "updated_at": "2026-04-20T20:53:57.374Z"}}, {"model": "opinions.comment", "pk": 1, "fields": {"opinion": 1, "author": ["olga"], "content": "Thanks, this helps with my shortlist.", "is_approved": true, "created_at": "2026-04-20T20:53:57.301Z", "updated_at": "2026-04-20T20:53:57.301Z"}}, {"model": "opinions.comment", "pk": 2, "fields": {"opinion": 6, "author": ["anna"], "content": "Agree on quiet cabin quality.", "is_approved": true, "created_at": "2026-04-20T20:53:57.306Z", "updated_at": "2026-04-20T20:53:57.306Z"}}, {"model": "opinions.comment", "pk": 3, "fields": {"opinion": 7, "author": ["piotr"], "content": "How is it on long trips?", "is_approved": true, "created_at": "2026-04-20T20:53:57.310Z", "updated_at": "2026-04-20T20:53:57.310Z"}}, {"model": "opinions.comment", "pk": 4, "fields": {"opinion": 4, "author": ["marek"], "content": "I had similar driv